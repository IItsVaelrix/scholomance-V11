VITE_DICTIONARY_API_URL=https://www.dictionaryapi.com/api/v3/references/collegiate/json
VITE_THESAURUS_API_URL=https://www.dictionaryapi.com/api/v3/references/thesaurus/json
VITE_SCHOLOMANCE_DICT_API_URL=http://127.0.0.1:8787/api/lexicon
# Preferred server-side key for backend word lookup routes.
SCHOLOMANCE_DICT_API_URL=http://127.0.0.1:8787/api/lexicon
# Optional Fastify lexicon sqlite path (production dictionary proxy).
SCHOLOMANCE_DICT_PATH=./scholomance_dict.sqlite
VITE_USE_CODEX_PIPELINE=true
VITE_USE_SERVER_WORD_LOOKUP=true
VITE_ENABLE_LOCAL_WORD_LOOKUP_FALLBACK=false
VITE_USE_SERVER_PANEL_ANALYSIS=true
VITE_USE_SERVER_ANALYSIS=true
VITE_ENABLE_SYNTAX_RHYME_LAYER=false
VITE_API_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-me-with-a-random-32-char-string
# Redis connection string (e.g., redis://localhost:6379 for local or Upstash URL for production)
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_SESSIONS=false
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=false
API_TIMEOUT_MS=5000
ENABLE_PANEL_ANALYSIS_CACHE=true
ENABLE_PANEL_ANALYSIS_REDIS_CACHE=true
PANEL_ANALYSIS_CACHE_TTL_MS=300000
PANEL_ANALYSIS_CACHE_MAX_SIZE=1000
DB_BUSY_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000
USER_DB_PATH=./scholomance_user.sqlite
COLLAB_DB_PATH=./scholomance_collab.sqlite
ENABLE_COLLAB_API=true
AUDIO_STORAGE_PATH=./public/audio
# Required in production. Use a long random token.
AUDIO_ADMIN_TOKEN=replace-with-a-long-random-token
# SendGrid API Key for production emails
SENDGRID_API_KEY=
EMAIL_FROM=noreply@scholomance.ai
ENABLE_DEV_AUTH=false
SERVE_FRONTEND=true
ENABLE_SYNTAX_RHYME_LAYER=false
NODE_ENV=development
