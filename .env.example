VITE_DICTIONARY_API_URL=https://www.dictionaryapi.com/api/v3/references/collegiate/json
VITE_THESAURUS_API_URL=https://www.dictionaryapi.com/api/v3/references/thesaurus/json
VITE_SCHOLOMANCE_DICT_API_URL=/api/lexicon
# Preferred server-side key for backend word lookup routes.
SCHOLOMANCE_DICT_API_URL=/api/lexicon
# Optional Fastify lexicon sqlite path (production dictionary proxy).
SCHOLOMANCE_DICT_PATH=./scholomance_dict.sqlite
SCHOLOMANCE_CORPUS_PATH=./scholomance_corpus.sqlite
VITE_USE_CODEX_PIPELINE=true
VITE_USE_SERVER_WORD_LOOKUP=true
VITE_ENABLE_LOCAL_WORD_LOOKUP_FALLBACK=false
VITE_USE_SERVER_PANEL_ANALYSIS=true
VITE_USE_SERVER_ANALYSIS=true
VITE_ENABLE_SYNTAX_RHYME_LAYER=false
VITE_API_BASE_URL=http://localhost:3000
SESSION_SECRET=replace-me-with-a-random-32-char-string
# Redis connection string (e.g., redis://localhost:6379 for local or Upstash URL for production)
REDIS_URL=redis://localhost:6379
ENABLE_REDIS_SESSIONS=false
HOST=0.0.0.0
PORT=3000
TRUST_PROXY=false
API_TIMEOUT_MS=5000
ENABLE_PANEL_ANALYSIS_CACHE=true
ENABLE_PANEL_ANALYSIS_REDIS_CACHE=true
ENABLE_RHYME_ASTROLOGY=false
# Optional build-time knobs for `npm run build:rhyme-astrology:index`
# RHYME_ASTROLOGY_OUTPUT_DIR=./dict_data/rhyme-astrology
# RHYME_ASTROLOGY_TARGET_LEXICON=50000
# RHYME_ASTROLOGY_HOT_EDGE_WORD_LIMIT=10000
# RHYME_ASTROLOGY_HOT_EDGE_TOP_K=50
# RHYME_ASTROLOGY_OVERSIZED_BUCKET_THRESHOLD=500
# RHYME_ASTROLOGY_BUCKET_CANDIDATE_CAP=600
# RHYME_ASTROLOGY_CLUSTER_LIMIT_PER_BUCKET=6
# RHYME_ASTROLOGY_STORAGE_TARGET_MB=100
# Optional runtime knobs for `/api/rhyme-astrology/query`
# RHYME_ASTROLOGY_CACHE_SIZE=500
# RHYME_ASTROLOGY_BUCKET_QUERY_CAP=200
# RHYME_ASTROLOGY_QUERY_MAX_CLUSTERS=12
# RHYME_ASTROLOGY_LEXICON_DB_PATH=./dict_data/rhyme-astrology/rhyme_lexicon.sqlite
# RHYME_ASTROLOGY_INDEX_DB_PATH=./dict_data/rhyme-astrology/rhyme_index.sqlite
# RHYME_ASTROLOGY_EDGES_DB_PATH=./dict_data/rhyme-astrology/rhyme_edges.sqlite
PANEL_ANALYSIS_CACHE_TTL_MS=300000
PANEL_ANALYSIS_CACHE_MAX_SIZE=1000
DB_BUSY_TIMEOUT_MS=5000
SHUTDOWN_TIMEOUT_MS=10000
USER_DB_PATH=./scholomance_user.sqlite
COLLAB_DB_PATH=./scholomance_collab.sqlite
ENABLE_COLLAB_API=true
# Remote Agent Access (Phase 3 — passwordless agent auth via bearer keys)
COLLAB_REMOTE_ACCESS=false
COLLAB_ALLOWED_ORIGINS=
COLLAB_AGENT_RATE_LIMIT_MAX=120
COLLAB_AGENT_RATE_LIMIT_WINDOW=1 minute
COLLAB_KEY_EXPIRY_DAYS=0
# HTTPS Configuration (production)
HTTPS_ENABLED=false
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=
AUDIO_STORAGE_PATH=./public/audio
# Required in production. Use a long random token.
AUDIO_ADMIN_TOKEN=replace-with-a-long-random-token
# Email Configuration (Providers: sendgrid, resend, smtp, postfix, console)
MAIL_PROVIDER=console
EMAIL_FROM=noreply@scholomance.ai
EMAIL_FROM_NAME=Scholomance

# SendGrid Configuration
SENDGRID_API_KEY=

# Resend Configuration
RESEND_API_KEY=

# SMTP / Postfix Configuration
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=false
# SMTP_TLS_REJECT_UNAUTHORIZED=true
# SMTP_GREETING_NAME=localhost

ENABLE_DEV_AUTH=false
SERVE_FRONTEND=true
ENABLE_SYNTAX_RHYME_LAYER=false
NODE_ENV=development
