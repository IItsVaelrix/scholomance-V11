{
  "name": "scholomance-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:app": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "test:visual": "playwright test --project=chromium --workers=1 --reporter=line",
    "test:visual:full": "node --input-type=module -e \"import { spawnSync } from 'node:child_process'; const cmd = process.platform === 'win32' ? 'npx.cmd' : 'npx'; const result = spawnSync(cmd, ['playwright', 'test'], { stdio: 'inherit', env: { ...process.env, PW_FULL_MATRIX: 'true' } }); process.exit(result.status ?? 1);\"",
    "security:qa": "node scripts/security/security-qa.js",
    "security:audit": "node scripts/security/dependency-audit.js",
    "test": "vitest",
    "preview": "vite preview",
    "start": "node codex/server/index.js",
    "start:server": "node codex/server/index.js",
    "db:setup": "node scripts/setup_database.cjs",
    "track:add:suno": "node scripts/add_suno_track.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/csrf-protection": "^7.1.0",
