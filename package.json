    "@fastify/rate-limit": "^10.3.0",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^8.3.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "cmudict": "^1.0.2",
    "connect-redis": "^9.0.0",
    "dotenv": "^17.2.4",
