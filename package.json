    "react-draggable": "^4.5.0",
    "react-markdown": "^10.1.0",
    "react-resizable": "^3.1.3",
    "react-resizable-panels": "^4.6.2",
    "react-router-dom": "^7.12.0",
    "react-use": "^17.6.0",
    "redis": "^5.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
